{
  "name": "candidates-notifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Scheduled email digests for the 2026 Chess Candidates tournaments.",
  "main": "dist/index.js",
  "scripts": {
    "cf:deploy": "wrangler deploy",
    "cf:dev": "wrangler dev",
    "dev": "tsx watch src/index.ts",
    "job:daily": "tsx src/scripts/runDailyDigest.ts",
    "email:test:live": "tsx src/scripts/sendLiveEvalTestEmail.ts",
    "start": "tsx src/index.ts",
    "email:test:round1": "tsx src/scripts/sendRound1TestEmail.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chess",
    "hono",
    "lichess",
    "resend"
  ],
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@upstash/redis": "^1.35.6",
    "chess.js": "^1.4.0",
    "dotenv": "^17.4.0",
    "hono": "^4.12.10",
    "node-cron": "^4.2.1",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.41.0"
  }
}
